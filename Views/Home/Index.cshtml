@{
    ViewData["Title"] = "Tablero Principal";
}

<div class="container mt-4">

    <!--  HEADER -->
    <div class="bg-light p-4 rounded shadow-sm mb-4">
        <h2 class="text-primary fw-bold">📊 Tablero Principal</h2>
        <p class="text-muted mb-0">
            Panorama general del sistema de gestión de consorcios
        </p>
    </div>

    <!--  KPI CARDS -->
    <div class="row g-3 mb-4 text-center">

        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Consorcios</h6>
                    <h2 class="fw-bold">@ViewBag.TotalConsorcios</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Unidades</h6>
                    <h2 class="fw-bold">@ViewBag.TotalUnidades</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Activas</h6>
                    <h2 class="fw-bold">@ViewBag.UnidadesActivas</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white shadow-sm">
                <div class="card-body">
                    <h6 class="mb-1">Gastos del Mes</h6>
                    <h4 class="fw-bold">$@ViewBag.GastosMesActual</h4>
                </div>
            </div>
        </div>

    </div>

    <!--  ACCESOS RÁPIDOS -->
    <div class="row g-3 text-center mb-4">

        <div class="col-md-4">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="text-primary">Consorcios</h5>
                        <p class="text-muted">
