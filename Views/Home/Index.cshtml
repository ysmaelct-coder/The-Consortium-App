@{
    ViewData["Title"] = "Inicio";
}

<div class="position-relative overflow-hidden text-center bg-dark text-white d-flex align-items-center justify-content-center shadow-sm" style="min-height: 75vh;">

    <video autoplay loop muted playsinline id="videoFondo" class="position-absolute top-50 start-50 translate-middle w-100 h-100" style="object-fit: cover; opacity: 0.3; z-index: 1; filter: grayscale(10%) brightness(90%); pointer-events: none;">
        <source src="videos/consorcio-bg.mp4" type="video/mp4" />
        Tu navegador no soporta video.
    </video>

    <div class="container position-relative py-5 px-4" style="z-index: 2; max-width: 900px;">
        <h1 class="display-2 fw-extrabold mb-3 text-white tracking-tight text-uppercase">
            The Consortium App
        </h1>

        <p class="lead fw-normal text-light-50 mb-5 fs-4 mx-auto border-top border-bottom border-light border-opacity-10 py-3" style="max-width: 700px; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">
            La solución definitiva, privada y escalable para la administración integral de consorcios, liquidación de expensas y control de gastos.
        </p>

        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center align-items-center">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5 py-3 fw-bold shadow border-0 tracking-wide btn-login-custom">
                🔑 Ingresar al Sistema
            </a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-5 py-3 fw-semibold tracking-wide btn-registro-custom">
                🏢 Registrar Empresa
            </a>
        </div>
    </div>
</div>

<div class="container my-5 py-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark display-6">Módulos Profesionales e Independientes</h2>
        <div class="mx-auto bg-danger mb-3 rounded" style="width: 60px; height: 4px;"></div>
        <p class="text-muted fs-5 mx-auto" style="max-width: 600px;">Arquitectura robusta diseñada para mantener la privacidad absoluta y el aislamiento total de tus datos corporativos.</p>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4 rounded-4 bg-white card-premium card-consorcios">
                <div class="fs-1 mb-3 text-primary bg-primary bg-opacity-10 rounded-circle mx-auto d-flex align-items-center justify-content-center contenedor-icono-chico" style="width: 80px; height: 80px;">
                    🏢
                </div>
                <h4 class="fw-bold card-title text-dark mb-2">Consorcios Centralizados</h4>
                <p class="card-text text-muted small px-2 mb-4">Alta de edificios o barrios cerrados, administración inteligente de coeficientes de copropiedad y control operativo total.</p>
                <div class="mt-auto">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-outline-primary px-4 py-2 rounded-pill fw-bold btn-card-action">Registrar Empresa</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 p-4 rounded-4 bg-white card-premium card-gastos">
                <div class="fs-1 mb-3 text-danger bg-danger bg-opacity-10 rounded-circle mx-auto d-flex align-items-center justify-content-center contenedor-icono-chico" style="width: 80px; height: 80px;">
                    💰
                </div>
                <h4 class="fw-bold card-title text-dark mb-2">Control de Gastos</h4>
                <p class="card-text text-muted small px-2 mb-4">Carga y procesamiento ágil de comprobantes con almacenamiento digitalizado e indexación de facturas (PDF o imágenes).</p>
                <div class="mt-auto">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-danger px-4 py-2 rounded-pill fw-bold btn-card-action text-white shadow-sm">🔑 Ingresar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 p-4 rounded-4 bg-white card-premium card-reportes">
                <div class="fs-1 mb-3 text-success bg-success bg-opacity-10 rounded-circle mx-auto d-flex align-items-center justify-content-center contenedor-icono-chico" style="width: 80px; height: 80px;">
                    📊
                </div>
                <h4 class="fw-bold card-title text-dark mb-2">Reportes & Expensas</h4>
                <p class="card-text text-muted small px-2 mb-4">Liquidación automatizada basada en el prorrateo real por unidad funcional, aislada herméticamente por inquilino.</p>
                <div class="mt-auto">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-success px-4 py-2 rounded-pill fw-bold btn-card-action text-white shadow-sm">🔑 Ingresar</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5 mt-5 border-top border-bottom border-light-subtle">
    <div class="container py-3">
        <div class="text-center mb-5">
            <h3 class="fw-bold text-dark display-6">Una experiencia administrativa ágil</h3>
            <p class="text-muted fs-5">Optimice los tiempos de gestión mediante herramientas visuales modernas, limpias e intuitivas.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="overflow-hidden rounded-4 shadow-sm bg-dark position-relative contenedor-foto" style="height: 240px;">
                    <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=600" class="w-100 h-100 imagen-zoom" style="object-fit: cover; opacity: 0.8;" alt="Infraestructura" />
                    <div class="position-absolute bottom-0 start-0 p-3 bg-gradient-dark w-100 text-white">
                        <p class="mb-0 fw-bold small tracking-wide">Infraestructura Moderna</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="overflow-hidden rounded-4 shadow-sm bg-dark position-relative contenedor-foto" style="height: 240px;">
                    <img src="https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?q=80&w=600" class="w-100 h-100 imagen-zoom" style="object-fit: cover; opacity: 0.8;" alt="Contabilidad" />
                    <div class="position-absolute bottom-0 start-0 p-3 bg-gradient-dark w-100 text-white">
                        <p class="mb-0 fw-bold small tracking-wide">Transparencia Financiera</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="overflow-hidden rounded-4 shadow-sm bg-dark position-relative contenedor-foto" style="height: 240px;">
                    <img src="data:image/jpeg;base64," class="w-100 h-100 imagen-zoom" style="object-fit: cover; opacity: 0.8;" alt="Métricas" />
                    <div class="position-absolute bottom-0 start-0 p-3 bg-gradient-dark w-100 text-white">
                        <p class="mb-0 fw-bold small tracking-wide">Reportes QuestPDF de Alta Precisión</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 850;
    }

    .bg-gradient-dark {
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
    }

    /* --- TARJETAS PREMIUM CON ANIMACIÓN --- */
    .card-premium {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.05) !important;
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease, border-color 0.4s ease;
    }

    /* --- ANIMACIÓN DE LOS CONTENEDORES REDONDOS DE LOS ICONOS --- */
    .contenedor-icono-chico {
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), background-color 0.3s ease, box-shadow 0.3s ease;
    }

    .btn-card-action {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    /* --- COMPORTAMIENTO EFECTO HOVER DE LAS TARJETAS --- */
    .card-premium:hover {
        transform: translateY(-10px);
    }

        /* El circulo del icono se agranda y rota levemente cuando se pasa el mouse por la tarjeta */
        .card-premium:hover .contenedor-icono-chico {
            transform: scale(1.12) rotate(3deg);
        }

        .card-premium:hover .btn-card-action {
            transform: scale(1.03);
        }

    /* 1. Modificaciones para Consorcios (Glow Azul) */
    .card-consorcios:hover {
        border-color: rgba(13, 110, 253, 0.3) !important;
        box-shadow: 0 15px 35px rgba(13, 110, 253, 0.12) !important;
    }
        /* El contenedor chico del icono reacciona de forma única */
        .card-consorcios:hover .contenedor-icono-chico {
            background-color: rgba(13, 110, 253, 0.2) !important;
            box-shadow: inset 0 0 10px rgba(13, 110, 253, 0.15), 0 4px 12px rgba(13, 110, 253, 0.15);
        }

    /* 2. Modificaciones para Gastos (Glow Rojo) */
    .card-gastos:hover {
        border-color: rgba(220, 53, 69, 0.3) !important;
        box-shadow: 0 15px 35px rgba(220, 53, 69, 0.12) !important;
    }
        /* El contenedor chico del icono reacciona de forma única */
        .card-gastos:hover .contenedor-icono-chico {
            background-color: rgba(220, 53, 69, 0.2) !important;
            box-shadow: inset 0 0 10px rgba(220, 53, 69, 0.15), 0 4px 12px rgba(220, 53, 69, 0.15);
        }

    /* 3. Modificaciones para Reportes (Glow Verde) */
    .card-reportes:hover {
        border-color: rgba(25, 135, 84, 0.3) !important;
        box-shadow: 0 15px 35px rgba(25, 135, 84, 0.12) !important;
    }
        /* El contenedor chico del icono reacciona de forma única */
        .card-reportes:hover .contenedor-icono-chico {
            background-color: rgba(25, 135, 84, 0.2) !important;
            box-shadow: inset 0 0 10px rgba(25, 135, 84, 0.15), 0 4px 12px rgba(25, 135, 84, 0.15);
        }

    /* --- INTERACCIONES DEL HERO Y OTROS --- */
    .btn-login-custom {
        background-color: #dc3545;
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

        .btn-login-custom:hover {
            background-color: #bb2d3b !important;
            transform: scale(1.02);
        }

    .btn-registro-custom {
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

        .btn-registro-custom:hover {
            transform: scale(1.02);
        }

    .contenedor-foto {
        cursor: pointer;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .imagen-zoom {
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .contenedor-foto:hover .imagen-zoom {
        transform: scale(1.05);
    }
</style>