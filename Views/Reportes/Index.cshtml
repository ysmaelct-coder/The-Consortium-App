@model IEnumerable<TheConsortiumApp.Models.LiquidacionExpensaDetalle>

@{
    ViewData["Title"] = "Reportes";
}

<div class="container-fluid mt-4">
    <div class="bg-white p-4 rounded shadow-sm border-start border-primary border-4 mb-4">
        <h2 class="fw-bold text-dark mb-1">📊 Reporte Estructural de Expensas</h2>
        <p class="text-muted mb-0">Genere y consulte las liquidaciones mensuales por consorcio.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3 py-2-5 d-flex align-items-center mb-4" role="alert">
            <span class="fs-5 me-2">⚠️</span>
            <div>@TempData["Error"]</div>
        </div>
    }

    <div class="card border-0 shadow-sm p-3 mb-4 bg-light">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold text-secondary">Consorcio</label>
                <select name="consorcioId" class="form-select">
                    @if (ViewBag.Consorcios != null)
                    {
                        foreach (var c in ViewBag.Consorcios)
                        {
                            <option value="@c.Id" selected="@(c.Id == ViewBag.ConsorcioIdSeleccionado)">
                                @c.Nombre
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold text-secondary">Año</label>
                <input type="number" name="year" value="@ViewBag.Year" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold text-secondary">Mes</label>
                <input type="number" name="month" value="@ViewBag.Month" class="form-control" />
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100 fw-bold">🔍 Filtrar</button>
            </div>
        </form>
    </div>

    <div class="mb-4 d-inline-flex flex-wrap gap-2">
        <form asp-action="Generar" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="consorcioId" value="@ViewBag.ConsorcioIdSeleccionado" />
            <input type="hidden" name="year" value="@ViewBag.Year" />
            <input type="hidden" name="month" value="@ViewBag.Month" />

            <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                ⚙️ Generar Expensas del Periodo
            </button>
        </form>

        @if (Model != null && Model.Any())
        {
            <a asp-controller="Reportes"
               asp-action="DescargarPdf"
               asp-route-consorcioId="@ViewBag.ConsorcioIdSeleccionado"
               asp-route-periodo="@ViewBag.Periodo"
               class="btn btn-danger px-4 fw-bold shadow-sm d-inline-flex align-items-center gap-2">
                📄 Exportar Reporte de Expensas (PDF)
            </a>
        }
    </div>

    <div class="alert alert-info rounded-3 shadow-sm border-0 d-flex justify-content-between align-items-center flex-wrap" role="alert">
        <div>
            <span class="fs-5">📅</span>
            <strong>Periodo Activo:</strong> <span class="badge bg-white text-info fs-6 border border-info ms-1">@(ViewBag.Periodo?.ToString().Insert(4, "-"))</span>
        </div>
        <div class="fs-5">
            <strong>Total Gastos Consolidados:</strong>
            <span class="text-dark fw-bold">$@ViewBag.TotalGastos.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-dark text-white fw-bold py-3">
            📋 Unidades Funcionales y Prorrateo
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small fw-bold">
                        <tr>
                            <th class="ps-4">Unidad</th>
                            <th>Propietario</th>
                            <th>Inquilino</th>
                            <th class="text-center">Porcentaje de Pago (Coeficiente)</th>
                            <th class="text-end pe-4">Monto Expensa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var d in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">
                                        @d.UnidadFuncional?.PisoDepto
                                    </td>

                                    <td class="text-dark fw-medium">
                                        @d.UnidadFuncional?.NombrePropietario
                                    </td>

                                    <td class="text-muted small">
                                        Idem Propietario
                                    </td>

                                    <td class="text-center fw-bold text-secondary">
                                        @((d.Coeficiente).ToString("N2")) %
                                    </td>

                                    <td class="text-end pe-4 fw-bold text-success fs-5">
                                        $@d.MontoCalculado.ToString("N2", new System.Globalization.CultureInfo("es-AR"))
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    No hay expensas generadas para este periodo. Haga clic en "Generar Expensas del Periodo".
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3" style="max-width: 500px;">
        <div class="card-header bg-white fw-bold border-bottom-0 pt-3">
            ⏱ Historial de Liquidaciones Recientes
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-striped mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Periodo</th>
                        <th class="text-end pe-3">Total Gastos</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Historico != null)
                    {
                        foreach (var h in ViewBag.Historico)
                        {
                            <tr>
                                <td class="ps-3">@(h.Periodo.ToString().Insert(4, "-"))</td>
                                <td class="text-end pe-3 fw-bold">$@h.TotalGastos.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>