@model TheConsortiumApp.Models.UnidadFuncional

@{
    ViewData["Title"] = "Nueva Unidad";
}

<div class="container-fluid mt-4" style="max-width: 800px;">
    <div class="bg-white p-4 rounded shadow-sm border-start border-success border-4 mb-4">
        <h2 class="fw-bold text-dark mb-1">🏢 Nueva Unidad Funcional</h2>
        <p class="text-muted mb-0">Complete los datos de la propiedad y sus condiciones de habitabilidad.</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-warning shadow-sm rounded-3">
            <strong>Hay errores en el formulario:</strong>
            <div asp-validation-summary="All" class="small"></div>
        </div>
    }

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="bg-white p-4 rounded shadow-sm">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="NroUnidad" class="form-label fw-semibold text-secondary">Número de Unidad</label>
                <input asp-for="NroUnidad" class="form-control" placeholder="Ej: 101" />
                <span asp-validation-for="NroUnidad" class="text-danger small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="PisoDepto" class="form-label fw-semibold text-secondary">Piso / Dpto</label>
                <input asp-for="PisoDepto" class="form-control" placeholder="Ej: 1° A" />
                <span asp-validation-for="PisoDepto" class="text-danger small"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Ambientes" class="form-label fw-semibold text-secondary">Cantidad de Ambientes</label>
                <select asp-for="Ambientes" class="form-select">
                    <option value="">Seleccione...</option>
                    @foreach (var item in Enum.GetValues(typeof(TheConsortiumApp.Models.TipoAmbientes)))
                    {
                        <option value="@item">@item</option>
                    }
                </select>
                <span asp-validation-for="Ambientes" class="text-danger small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="ConsorcioId" class="form-label fw-semibold text-secondary">Consorcio Asignado</label>
                <select asp-for="ConsorcioId" class="form-select">
                    <option value="">Seleccione...</option>
                    @if (ViewBag.Consorcios != null)
                    {
                        foreach (var c in ViewBag.Consorcios)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    }
                </select>
                <span asp-validation-for="ConsorcioId" class="text-danger small"></span>
            </div>
        </div>

        <input type="hidden" asp-for="Coeficiente" value="0" />

        <hr class="text-muted opacity-25 my-4">

        <h5 class="fw-bold text-dark mb-3">👤 Información del Propietario</h5>
        <div class="mb-4">
            <label asp-for="NombrePropietario" class="form-label fw-semibold text-secondary">Nombre Completo del Propietario</label>
            <input asp-for="NombrePropietario" class="form-control" placeholder="Ej: Juan Pérez" />
            <span asp-validation-for="NombrePropietario" class="text-danger small"></span>
        </div>

        <hr class="text-muted opacity-25 my-4">

        <div class="form-check form-switch mb-4 p-3 bg-light rounded-3 border-start border-info border-3 ms-0 ps-5">
            <input class="form-check-input" type="checkbox" role="switch" asp-for="EstaAlquilada" id="chkEstaAlquilada">
            <label class="form-check-label fw-bold text-dark" for="chkEstaAlquilada">
                ¿La unidad se encuentra alquilada actualmente?
            </label>
            <div class="text-muted small">Active esta opción si reside un inquilino y posee un contrato legal.</div>
        </div>

        <div id="panelInquilino" class="p-3 border rounded-3 bg-white mb-4 shadow-sm align-items-center" style="display: none; border-color: #bee5eb !important;">
            <h6 class="fw-bold text-info mb-3"><i class="bi bi-file-earmark-text"></i> Credenciales y Documentación de Locación</h6>

            <div class="mb-3">
                <label asp-for="NombreInquilino" class="form-label fw-semibold text-secondary">Nombre Completo del Inquilino</label>
                <input asp-for="NombreInquilino" id="txtNombreInquilino" class="form-control" placeholder="Ej: Carlos Gómez" />
                <span asp-validation-for="NombreInquilino" class="text-danger small"></span>
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold text-secondary">Adjuntar Contrato de Alquiler firmado (PDF / Imagen)</label>
                <input type="file" name="archivoContrato" id="fileContrato" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                <div class="form-text small text-muted">Formatos permitidos: PDF, JPG, PNG. Máximo 5MB.</div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">Guardar Unidad</button>
            <a asp-action="Index" class="btn btn-secondary px-4 fw-semibold">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const checkbox = document.getElementById("chkEstaAlquilada");
            const panel = document.getElementById("panelInquilino");
            const inputInquilino = document.getElementById("txtNombreInquilino");
            const fileContrato = document.getElementById("fileContrato");

            function alternarPanelInquilino() {
                if (checkbox.checked) {
                    // Mostrar de manera limpia
                    panel.style.display = "block";
                    inputInquilino.required = true;
                    fileContrato.required = true; // Hace que el archivo sea obligatorio si está alquilada
                } else {
                    // Ocultar y vaciar campos para evitar ruidos en la base de datos
                    panel.style.display = "none";
                    inputInquilino.required = false;
                    fileContrato.required = false;
                    inputInquilino.value = "";
                    fileContrato.value = "";
                }
            }

            // Ejecutar al cargar la página por si vuelve con errores de validación
            alternarPanelInquilino();

            // Escuchar cambios en el interruptor switch
            checkbox.addEventListener("change", alternarPanelInquilino);
        });
    </script>
}