@model TheConsortiumApp.Models.Empresa

@{
    ViewData["Title"] = "Detalle de Empresa";
}

<h2>Detalle de Empresa</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h4 class="mb-3">@Model.RazonSocial</h4>

        <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
        <p class="mb-1"><strong>CUIT:</strong> @Model.Cuit</p>
        <p class="mb-0"><strong>Total de consorcios:</strong> @Model.Consorcios.Count</p>
    </div>
</div>

<h4>Consorcios registrados</h4>

@if (Model.Consorcios.Any())
{
    <div class="row">
       @foreach (var c in Model.Consorcios)
       {
           <div class="card mb-3 shadow-sm">
               <div class="card-body">

                   <h5 class="text-primary">@c.Nombre</h5>

                   <p><strong>Dirección:</strong> @c.Direccion</p>
                   <p><strong>Localidad:</strong> @c.Localidad</p>

                   <p><strong>Creado por:</strong> @c.CreadoPorEmail</p>
                   <p><strong>Fecha creación:</strong> @c.FechaCreacion.ToString("dd/MM/yyyy")</p>

                   <p><strong>Total departamentos:</strong> @c.CantidadDepartamentos</p>

                   <p>
                       <strong>Unidades registradas:</strong>
                       @(c.UnidadesFuncionales?.Count() ?? 0)
                   </p>

                   <p>
                       <strong>Unidades activas:</strong>
                       @(c.UnidadesFuncionales?.Count(u => u.EstaAlquilada) ?? 0)
                   </p>

                   <p>
                       <strong>Total gastos:</strong>
                       $@(c.Gastos?.Sum(g => g.Monto) ?? 0)
                   </p>

                   <hr />

                   @if (c.UnidadesFuncionales != null && c.UnidadesFuncionales.Any())
                   {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Piso</th>
                                    <th>Propietario / Inquilino</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in c.UnidadesFuncionales)
                                {
                                    <tr>
                                        <td>@u.PisoDepto</td>
                                        <td>@u.Propietario</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                   }

               </div>
           </div>
       }
    </div>
}
else
{
    <div class="alert alert-secondary">
        Esta empresa no tiene consorcios registrados.
    </div>
}

<a asp-action="Index" class="btn btn-secondary">Volver</a>