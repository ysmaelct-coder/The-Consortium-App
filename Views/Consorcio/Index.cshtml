@model IEnumerable<TheConsortiumApp.Models.Consorcio>

<h2>Consorcios</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    + Nuevo Consorcio
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Dirección</th>
            <th>Localidad</th>
            <th>Unidades</th>
            <th>Gastos</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Nombre</td>
                <td>@c.Direccion</td>
                <td>@c.Localidad</td>

                <td>@c.UnidadesFuncionales?.Count()</td>
                <td>$@(c.Gastos?.Sum(g => g.Monto) ?? 0)</td>

                <td>
                    <a asp-controller="Consorcio"
                       asp-action="Details"
                       asp-route-id="@c.Id"
                       class="btn btn-info btn-sm">
                        Ver
                    </a>

                    <a asp-controller="Consorcio"
                       asp-action="Edit"
                       asp-route-id="@c.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-controller="Consorcio"
                       asp-action="Delete"
                       asp-route-id="@c.Id"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('¿Eliminar consorcio?');">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>