@model IEnumerable<TheConsortiumApp.Models.Consorcio>

@{
    ViewData["Title"] = "Consorcios";
}

<h2>Consorcios</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    + Nuevo Consorcio
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Dirección</th>
            <th>Localidad</th>
            <th>Unidades</th>
            <th>Gastos</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Nombre</td>
                <td>@c.Direccion</td>
                <td>@c.Localidad</td>
                <td>@(c.UnidadesFuncionales?.Count() ?? 0)</td>
                <td>$@(c.Gastos?.Sum(g => g.Monto) ?? 0)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>