@{
    ViewData["Title"] = "Ingreso al Sistema";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-lg mt-5">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <h2 class="font-weight-bold text-primary">
                            Contreras &amp; Asociados
                        </h2>
                        <p class="text-muted">
                            Sistema de Gestión de Consorcios
                        </p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group mb-3">
                            <label class="form-label small font-weight-bold">Correo Electrónico</label>
                            <input type="email" name="email" class="form-control form-control-lg"
                                   placeholder="admin@empresa.com" required />
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label small font-weight-bold">Contraseña</label>
                            <input type="password" name="password" class="form-control form-control-lg"
                                   placeholder="••••••••" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Ingresar
                        </button>
                    </form>

                    <!-- 🔥 BOTÓN DE REGISTRO -->
                    <a asp-action="Register"
                       class="btn btn-link text-center mt-3 d-block">
                        Crear nueva cuenta
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>