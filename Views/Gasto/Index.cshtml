@model IEnumerable<TheConsortiumApp.Models.Gasto>

@{
    ViewData["Title"] = "Listado de Gastos";
}

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center flex-wrap mb-4 bg-white p-3 rounded shadow-sm border-start border-danger border-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">📋 Gestión de Gastos</h2>
            <p class="text-muted mb-0">Consulte, filtre y registre los movimientos financieros de los consorcios.</p>
        </div>
        <div class="mt-2 mt-md-0 d-flex gap-2">
            <a asp-action="Create" class="btn btn-danger d-flex align-items-center gap-2 fw-semibold shadow-sm">
                Nuevo Gasto
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary uppercase small fw-bold">
                        <tr>
                            <th class="ps-4 py-3">Fecha</th>
                            <th class="py-3">Consorcio</th>
                            <th class="py-3">Concepto / Descripción</th>
                            <th class="py-3">Categoría</th>
                            <th class="py-3 text-end">Monto</th>
                            <th class="py-3 text-center">Comprobante</th>
                            <th class="pe-4 py-3 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var gasto in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium text-muted">
                                        @gasto.FechaRegistro.ToString("dd/MM/yyyy")
                                    </td>

                                    <td class="fw-bold text-primary">
                                        @(gasto.Consorcio?.Nombre ?? "No asignado")
                                    </td>

                                    <td class="text-dark fw-medium">
                                        @gasto.Concepto
                                    </td>

                                    <td>
                                        <span class="badge @ObtenerClaseBadge(gasto.Categoria.ToString()) px-2.5 py-1.5 rounded-2 text-capitalize">
                                            @gasto.Categoria
                                        </span>
                                    </td>

                                    <td class="text-end fw-bold text-dark fs-5">
                                        $@gasto.Monto.ToString("N2", new System.Globalization.CultureInfo("es-AR"))
                                    </td>

                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(gasto.ArchivoFactura))
                                        {
                                            <a href="~/facturas/@gasto.ArchivoFactura" target="_blank" class="btn btn-sm btn-light border rounded-circle text-danger p-2 shadow-sm" title="Ver Factura">
                                                📄
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Sin archivo</span>
                                        }
                                    </td>

                                    <td class="pe-4 text-center">
                                        <div class="d-inline-flex gap-1">
                                            <button onclick="confirmarEliminar(@gasto.Id, '@gasto.Concepto')" class="btn btn-sm btn-outline-secondary p-2 rounded-2 border-0 hover-danger" title="Eliminar Gasto">
                                                🗑️
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <div class="fs-4 mb-2">empty_dashboard</div>
                                    <p class="mb-0">No se encontraron gastos registrados para tu usuario.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-light border text-muted fw-semibold">
            ⬅ Volver al Tablero
        </a>
    </div>
</div>

@functions {
    public string ObtenerClaseBadge(string categoria)
    {
        return categoria.ToLower() switch
        {
            "sueldos" => "bg-primary-subtle text-primary border border-primary-subtle",
            "mantenimiento" => "bg-warning-subtle text-warning-emphasis border border-warning-subtle",
            "servicios" => "bg-info-subtle text-info-emphasis border border-info-subtle",
            "honorarios" => "bg-success-subtle text-success border border-success-subtle",
            "limpieza" => "bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle",
            "seguros" => "bg-danger-subtle text-danger border border-danger-subtle",
            _ => "bg-light text-dark border"
        };
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmarEliminar(id, concepto) {
        Swal.fire({
        title: '¿Eliminar este gasto?',
        text: `Vas a borrar: "${concepto}". Esta acción no se puede deshacer.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar'
        }).then((result) => {
        if (result.isConfirmed) {
        window.location.href = `@Url.Action("Delete", "Gasto")/${id}`;
        }
        });
        }
    </script>
}